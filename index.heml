    <!-- 右下固定ダウンロードボタン -->
    <button id="download-btn" onclick="downloadHTML()" class="fixed bottom-6 right-6 z-50 bg-brand-500 hover:bg-brand-400 text-black font-bold py-3 px-6 rounded-full shadow-[0_4px_15px_rgba(212,175,55,0.4)] border border-brand-300 transition-transform hover:scale-105 flex items-center gap-2">
        <i class="fa-solid fa-download"></i>
        <span>HTMLをダウンロード</span>
    </button>

    <script>
        function downloadHTML() {
            // 現在のHTMLコンテンツを取得
            const htmlContent = document.documentElement.outerHTML;
            
            // DOMParserを使用してHTMLをパースし、操作用のDOMを作成
            const parser = new DOMParser();
            const doc = parser.parseFromString(htmlContent, 'text/html');
            
            // コピーしたDOMからダウンロードボタン自身を削除
            const btnToRemove = doc.getElementById('download-btn');
            if (btnToRemove) {
                btnToRemove.remove();
            }

            // DOCTYPEを追加して完全なHTML文字列を再構築
            const finalHTML = '<!DOCTYPE html>\n' + doc.documentElement.outerHTML;
            
            // Blobを作成してダウンロードリンクを発火
            const blob = new Blob([finalHTML], { type: 'text/html;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'amazon_strategy_report_kids.html';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }
    </script>
</body>
</html>
